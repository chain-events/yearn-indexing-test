# GraphQL endpoint exposed by Hasura in front of the envio indexer's Postgres
GRAPHQL_URL=https://envio-gql.yearn.dev/v1/graphql

# Bearer token (JWT signed with HASURA_GRAPHQL_JWT_SECRET) — sent as
# `Authorization: Bearer <token>`. The JWT claims_map on graphql-engine pins the
# request to the readonly role, so chain_metadata must be granted to that role.
HASURA_GRAPHQL_JWT=

# Path to the envio indexer project on disk (used to read the envio version)
INDEXER_PROJECT_PATH=../indexer

# Probe the envio indexer's own HTTP server (Prometheus /metrics + /health).
# Locally, set the full URL. On Render, the blueprint wires INDEXER_HOST via
# fromService and the server builds http://<host>:<INDEXER_PORT>.
INDEXER_URL=http://localhost:9898
# INDEXER_HOST=
# INDEXER_PORT=9898

# Port the dashboard server listens on
PORT=4100
