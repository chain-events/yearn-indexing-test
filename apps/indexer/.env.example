# Envio indexer access
ENVIO_GRAPHQL_URL=http://localhost:8080/v1/graphql
# JWT token for Bearer auth to the Envio GraphQL endpoint
ENVIO_PASSWORD=

# Core Envio runtime config
ENVIO_PG_SSL_MODE=false
HASURA_GRAPHQL_ROLE=admin
ENVIO_THROTTLE_CHAIN_METADATA_INTERVAL_MILLIS=500
ENVIO_THROTTLE_PRUNE_STALE_DATA_INTERVAL_MILLIS=30000
ENVIO_THROTTLE_LIVE_METRICS_BENCHMARK_INTERVAL_MILLIS=1000
ENVIO_THROTTLE_JSON_FILE_BENCHMARK_INTERVAL_MILLIS=500

# RPC selection (choose one)
# Global override (highest priority)
ENVIO_RPC_URL=

# Chain-specific RPCs (used when --chain is provided)
ENVIO_RPC_URL_ETHEREUM=https://lb.drpc.live/ethereum/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_OPTIMISM=https://lb.drpc.live/optimism/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_GNOSIS=https://lb.drpc.live/gnosis/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_BASE=https://lb.drpc.live/base/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_ARBITRUM=https://lb.drpc.live/arbitrum/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_POLYGON=https://lb.drpc.live/polygon/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_BERACHAIN=https://lb.drpc.live/berachain/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
ENVIO_RPC_URL_KATANA=https://lb.drpc.live/katana/AqnDDmg600B7kro8HKYKS7lGwTlbWrQR8bIuIqM_iWcm
