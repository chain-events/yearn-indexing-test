{
  "name": "envio-indexer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "tsc --clean",
    "build": "tsc --build",
    "watch": "tsc --watch",
    "mocha": "vitest run",
    "codegen": "envio codegen",
    "dev": "envio dev",
    "migrate": "envio local db-migrate up",
    "start": "node bin/start-envio.mjs",
    "sync:vaults": "node scripts/update_kong_vaults.js",
    "test": "vitest run",
    "calc-fees": "tsc -p tsconfig.calc.json && node build/calc/calculate-depositor-fees.js",
    "jwt:generate": "node scripts/generate_hasura_jwt.js"
  },
  "devDependencies": {
    "@types/node": "20.17.0",
    "dotenv": "^17.4.1",
    "vitest": "^3.1.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "envio": "3.0.0-alpha.21",
    "viem": "^2.47.11"
  },
  "optionalDependencies": {
    "generated": "link:generated"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
